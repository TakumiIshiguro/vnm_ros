<launch>
  <node pkg="vnm_ros" type="visualize_dataset.py"
        name="vnm_visualize_dataset" output="screen">
    <param name="config_dir" value="$(find vnm_ros)/config"/>
  </node>

  <node pkg="rviz" type="rviz" name="vnm_dataset_rviz"
        args="-d $(find vnm_ros)/rviz/dataset.rviz" output="screen"/>
</launch>
